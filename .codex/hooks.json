{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "ATC_PROVIDER=codex node \"$(git rev-parse --show-toplevel)/dashboard/scripts/codex-hook-forwarder.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ATC_PROVIDER=codex node \"$(git rev-parse --show-toplevel)/dashboard/scripts/codex-hook-forwarder.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ATC_PROVIDER=codex node \"$(git rev-parse --show-toplevel)/dashboard/scripts/codex-hook-forwarder.mjs\""
          }
        ]
      }
    ]
  }
}
